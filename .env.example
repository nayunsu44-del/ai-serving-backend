API_KEYS=local-test-key
# Auth mode / 인증 모드: api_key 기본값, JWT 병행 사용은 api_key,jwt
AUTH_MODE=api_key
# JWT issuer / JWT 발급자 URL
# JWT_ISSUER=https://issuer.example.com
# JWT audience / JWT 대상 audience
# JWT_AUDIENCE=ai-serving-backend
# JWKS URL for JWT signatures / JWT 서명 검증용 JWKS URL
# JWT_JWKS_URL=https://issuer.example.com/.well-known/jwks.json
# JWT algorithms / 허용 JWT 알고리즘
# JWT_ALGORITHMS=RS256
# JWT scope claim / 그룹 claim 이름
# JWT_SCOPE_CLAIM=groups
# JWT group to scope map / 그룹-스코프 매핑: group=scope
# JWT_GROUP_SCOPE_MAP=ai-user=chat,ai-admin=admin
# JWT org claim / 조직 ID claim 이름
# JWT_ORG_CLAIM=org_id
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
# API key last_used_at update debounce in seconds / API 키 last_used_at 갱신 최소 간격(초)
API_KEY_LAST_USED_MIN_INTERVAL_SECONDS=60
DATABASE_URL=sqlite+aiosqlite:///./data/app.db
# DATABASE_URL=postgresql+asyncpg://app:change-me@postgres:5432/ai_serving
RATE_LIMIT_RPM=60
RATE_LIMIT_BACKEND=memory
# RATE_LIMIT_STRICT=true
# REDIS_URL=redis://redis:6379/0
PRE_AUTH_RPM_PER_IP=30
TRUSTED_PROXIES=
TRUST_FORWARDED_FOR=false
AUDIT_SYNC=false
AUDIT_FALLBACK_PATH=./data/audit_fallback.jsonl
# Audit message storage / 메시지 저장 여부: Chunk B persistence option.
AUDIT_STORE_MESSAGES=false
# PII masking / 개인정보 마스킹: redact before upstream provider calls.
PII_MASKING_ENABLED=true
# PII types / 마스킹 대상: rrn,card,phone,email
PII_TYPES=rrn,card,phone,email
# Policy mode / 정책 모드: block,log_only,disabled
POLICY_MODE=log_only
# Forbidden patterns / 금지 패턴: rule_id=regex comma-separated, case-insensitive; no commas in regex MVP.
FORBIDDEN_PATTERNS=
LOG_LEVEL=INFO
DEFAULT_MAX_TOKENS=1024
MAX_REQUEST_BYTES=1048576
MAX_MESSAGES=200
MAX_MESSAGE_CHARS=100000
MAX_MODEL_NAME_CHARS=128
MAX_OUTPUT_TOKENS=4096
STREAM_MAX_DURATION_SECONDS=300
MAX_CONCURRENT_STREAMS_PER_KEY=4
ALLOWED_HOSTS=*
DOCS_ENABLED=true
OPENAI_MODELS=gpt-4o,gpt-4o-mini
ANTHROPIC_MODELS=claude-sonnet-4-6,claude-3-5-haiku-latest
POSTGRES_USER=app
POSTGRES_PASSWORD=change-me
POSTGRES_DB=ai_serving
